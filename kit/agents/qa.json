{
  "name": "qa",
  "description": "SDLC S5 (QA). Test scenarios từ AC, auto + manual test, bug classification, RCA. Trigger: /s5",
  "prompt": "file://./qa.md",
  "tools": [
    "read",
    "write",
    "shell",
    "@redmine",
    "@figma"
  ],
  "allowedTools": [
    "read",
    "write",
    "shell",
    "@redmine/redmine_request",
    "@figma/get_figma_data"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "openspec/**",
        ".kiro/memory/**",
        "test/**",
        "tests/**",
        "e2e/**",
        "spec/**",
        "__tests__/**"
      ]
    },
    "shell": {
      "allowedCommands": [
        "npx",
        "npm",
        "grep",
        "cat",
        "curl",
        "docker",
        "docker compose",
        "docker-compose",
        "sleep",
        "python3",
        "node",
        "wc",
        "head",
        "tail"
      ]
    }
  },
  "resources": [
    "skill://.kiro/skills/qa-test-design/SKILL.md",
    "skill://.kiro/skills/qa-analysis/SKILL.md",
    "skill://.kiro/skills/qa-execution/SKILL.md",
    "skill://.kiro/skills/security-audit/SKILL.md",
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/steering",
      "name": "Steering",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/sdlc.config.json",
      "name": "Sdlc.config",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/context/project.md",
      "name": "Project",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/context/glossary.md",
      "name": "Glossary",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/ai",
      "name": "Ai",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/context/conventions.md",
      "name": "Conventions",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/context/stack.md",
      "name": "Stack",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/context/legacy-ref.md",
      "name": "LegacyRef",
      "indexType": "best",
      "autoUpdate": false
    }
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "python3 .kiro/agents/scripts/agent-spawn-context.py qa",
        "timeout_ms": 5000,
        "cache_ttl_seconds": 15
      }
    ],
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "python3 .kiro/agents/scripts/check-write-path.py qa",
        "timeout_ms": 3000
      }
    ],
    "stop": [
      {
        "command": "echo '' && echo '=== Uncommitted ===' && git diff --stat openspec/ 2>/dev/null | tail -5 || true",
        "timeout_ms": 5000
      },
      {
        "command": "node .kiro/tools/cpp-guard.mjs --role qa 2>/dev/null || true",
        "timeout_ms": 4000
      }
    ],
    "userPromptSubmit": [
      {
        "command": "python3 -c \"\nimport json,sys,re\nd=json.load(sys.stdin)\nmsg=d.get('user_message','')\nm=re.search(r'\\b(\\d{4,6})\\b',msg)\nif m: print(f'[Auto-context] ticket_id detected: {m.group(1)}')\n\" 2>/dev/null||true",
        "timeout_ms": 1000
      }
    ]
  },
  "includeMcpJson": true,
  "model": "claude-sonnet-4.6",
  "keyboardShortcut": "ctrl+4",
  "welcomeMessage": "QA sẵn sàng. Dùng /s5 {ticket_id} {feature-slug} để bắt đầu kiểm thử."
}
