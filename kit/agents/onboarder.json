{
  "name": "onboarder",
  "description": "Project Onboarder — scans the repo to auto-detect stack/architecture, interviews for gaps, fills the .kiro/context/ contract, and wires context to each agent via the context-mapper. Run once when adopting the kit in a project, or anytime context changes.",
  "prompt": "file://./onboarder.md",
  "tools": [
    "read",
    "write",
    "shell"
  ],
  "allowedTools": [
    "read",
    "write",
    "shell"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        ".kiro/context/**",
        ".kiro/context-map.json"
      ]
    },
    "shell": {
      "allowedCommands": [
        "cat",
        "grep",
        "ls",
        "find",
        "test",
        "head",
        "wc",
        "node",
        "rtk"
      ]
    }
  },
  "resources": [
    "skill://.kiro/skills/context-mapper/SKILL.md",
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/context",
      "name": "ContextContract",
      "indexType": "best",
      "autoUpdate": true
    }
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "python3 .kiro/agents/scripts/agent-spawn-context.py onboarder",
        "timeout_ms": 5000,
        "cache_ttl_seconds": 15
      }
    ],
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "python3 .kiro/agents/scripts/check-write-path.py onboarder",
        "timeout_ms": 3000
      }
    ]
  },
  "includeMcpJson": true,
  "model": "claude-opus-4.8",
  "keyboardShortcut": "ctrl+9",
  "welcomeMessage": "Onboarder. Tôi sẽ quét dự án, hỏi phần còn thiếu, điền .kiro/context/ và wire context cho từng agent. Gõ 'bắt đầu' để onboard."
}
