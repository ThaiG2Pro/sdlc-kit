{
  "name": "sdlc-fast",
  "description": "SDLC Orchestrator for FAST-TRACK flows (bugfix/hotfix) — skips S1–S3, drives minimal build + verify. Use: 'sdlc bugfix {slug}', 'fix bug …', 'hotfix {slug}', or natural language.",
  "prompt": "file://./sdlc-fast.md",
  "tools": [
    "read",
    "write",
    "shell"
  ],
  "allowedTools": [
    "read",
    "write",
    "shell"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "openspec/**",
        ".kiro/memory/**"
      ]
    },
    "shell": {
      "allowedCommands": [
        "cat",
        "grep",
        "ls",
        "test",
        "python3",
        "node",
        "openspec"
      ]
    }
  },
  "resources": [
    "skill://.kiro/skills/sdlc-orchestration-core/SKILL.md",
    "skill://.kiro/skills/spec-auditor/SKILL.md",
    "skill://.kiro/skills/cross-artifact-audit/SKILL.md",
    "skill://.kiro/skills/sprint-retro/SKILL.md",
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/steering",
      "name": "Steering",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/sdlc.config.json",
      "name": "Sdlc.config",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/context/project.md",
      "name": "Project",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/context/glossary.md",
      "name": "Glossary",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/context/conventions.md",
      "name": "Conventions",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/pipelines.json",
      "name": "Pipelines",
      "indexType": "best",
      "autoUpdate": false
    }
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "python3 .kiro/agents/scripts/agent-spawn-context.py sdlc-fast",
        "timeout_ms": 5000,
        "cache_ttl_seconds": 15
      }
    ],
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "python3 .kiro/agents/scripts/check-write-path.py sdlc-fast",
        "timeout_ms": 3000
      }
    ],
    "stop": [
      {
        "command": "echo '' && echo '=== Uncommitted ===' && git diff --stat openspec/ 2>/dev/null | tail -5 || true",
        "timeout_ms": 5000
      }
    ],
    "userPromptSubmit": [
      {
        "command": "python3 -c \"\nimport json,sys,re\nd=json.load(sys.stdin)\nmsg=d.get('user_message','').lower()\nif any(k in msg for k in ['approve','nogo','no-go','dispute','status','continue','bugfix','hotfix','fix bug']):\n    print('[Pipeline] Action detected in message')\nm=re.search(r'\\b(\\d{4,6})\\b',d.get('user_message',''))\nif m: print(f'[Auto-context] ticket_id: {m.group(1)}')\n\" 2>/dev/null||true",
        "timeout_ms": 1000
      }
    ]
  },
  "includeMcpJson": true,
  "model": "claude-sonnet-4.6",
  "keyboardShortcut": "ctrl+5",
  "welcomeMessage": "SDLC Fast-track (bugfix/hotfix). Nói \"fix bug {tên}\" hoặc \"hotfix {tên}\" để bắt đầu; \"approve\"/\"status\" để quản lý. Tính năng mới/CR → dùng sdlc-full (ctrl+0)."
}
