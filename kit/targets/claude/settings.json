{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Write(.claude/settings.json)",
      "Edit(.claude/settings.json)",
      "Write(.claude/agents/scripts/**)",
      "Edit(.claude/agents/scripts/**)",
      "Write(.claude/agents/**)",
      "Edit(.claude/agents/**)",
      "Write(.claude/commands/**)",
      "Edit(.claude/commands/**)",
      "Write(openspec/specs/**)",
      "Edit(openspec/specs/**)"
    ],
    "allow": [
      "Bash(openspec:*)",
      "Bash(node .claude/tools/:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git checkout -b:*)",
      "Bash(git switch -c:*)",
      "Bash(git worktree add:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Task",
      "Write(openspec/**)",
      "Edit(openspec/**)",
      "Write(memory/**)",
      "Edit(memory/**)",
      "Write(.claude/memory/**)",
      "Edit(.claude/memory/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 .claude/agents/scripts/check-shell-command.py", "timeout": 5 }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "python3 .claude/agents/scripts/check-write-path.py", "timeout": 5 }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "python3 .claude/agents/scripts/check-kit-version.py .claude", "timeout": 5 },
          { "type": "command", "command": "python3 .claude/agents/scripts/agent-spawn-context.py", "timeout": 5 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "python3 -c \"import json,sys,re;d=json.load(sys.stdin);m=re.search(r'\\b(\\d{4,6})\\b',d.get('prompt',''));print('[Auto-context] ticket_id detected: '+m.group(1)) if m else None\" 2>/dev/null || true", "timeout": 3 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "OUT=$(git diff --name-only -- . ':(exclude)openspec' ':(exclude)memory' ':(exclude).claude' 2>/dev/null); [ -n \"$OUT\" ] && { echo '⚠ NON-SPEC FILE CHANGES detected — the orchestrator (main session) must NOT write code; only the developer subagent (S4) may. Verify these came from the developer:'; echo \"$OUT\" | head -20; }; true", "timeout": 5 }
        ]
      }
    ]
  }
}
