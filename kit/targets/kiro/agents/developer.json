{
  "name": "developer",
  "description": "SDLC S4 (Build) + S6 (Release Prep). Code gen theo design, unit tests ≥80%, self-review, release checklist. Drives OpenSpec change workspaces. Trigger: /s4, /s6",
  "prompt": "file://./developer.md",
  "tools": [
    "read",
    "write",
    "shell",
    "code"
  ],
  "allowedTools": [
    "read",
    "write",
    "code",
    "shell"
  ],
  "toolsSettings": {
    "write": {
      "allowedPaths": [
        "src/**",
        "app/**",
        "apps/**",
        "lib/**",
        "pkg/**",
        "internal/**",
        "cmd/**",
        "prisma/**",
        "migrations/**",
        "database/**",
        "db/**",
        "test/**",
        "tests/**",
        "e2e/**",
        "spec/**",
        "__tests__/**",
        "docker/**",
        "scripts/**",
        "config/**",
        "openspec/**",
        "memory/**",
        ".github/**",
        "package.json",
        "package-lock.json",
        "pnpm-lock.yaml",
        "yarn.lock",
        "nest-cli.json",
        "composer.json",
        "composer.lock",
        "artisan",
        "pyproject.toml",
        "phpunit.xml",
        "phpunit.xml.dist",
        "Makefile",
        "Dockerfile",
        "README.md",
        "ROADMAP.md",
        "mise.toml",
        ".gitlab-ci.yml",
        ".env.example",
        ".env.sample",
        ".env.local.example",
        "docker-compose.yml",
        "docker-compose.yaml",
        "docker-compose.dev.yml",
        "docker-compose.local.yml",
        "docker-compose.override.yml",
        "compose.yml",
        "compose.yaml",
        "*.config.ts",
        "*.config.js",
        "*.config.mjs",
        "*.config.cjs",
        "*tsconfig.json",
        "*tsconfig.build.json",
        "*jsconfig.json",
        "*.prettierrc",
        "*.prettierignore",
        "*.eslintrc",
        "*.eslintrc.js",
        "*.eslintrc.json",
        "*biome.json",
        "*Dockerfile"
      ]
    },
    "shell": {
      "allowedCommands": [
        "*"
      ]
    }
  },
  "resources": [
    "skill://.kiro/skills/verification-loop/SKILL.md",
    "skill://.kiro/skills/commit-message-helper/SKILL.md",
    "skill://.kiro/skills/security-review/SKILL.md",
    "skill://.kiro/skills/test-generator/SKILL.md",
    "skill://.kiro/skills/coding-standards/SKILL.md",
    "skill://.kiro/skills/deployment-patterns/SKILL.md",
    "skill://.kiro/skills/sonar-local/SKILL.md",
    "skill://.kiro/skills/search-first/SKILL.md",
    "skill://.kiro/skills/api-documentation-checker/SKILL.md",
    "skill://.kiro/skills/agentic-engineering/SKILL.md",
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/steering",
      "name": "Steering",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./sdlc.config.json",
      "name": "Sdlc.config",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./context/project.md",
      "name": "Project",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./context/glossary.md",
      "name": "Glossary",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./.kiro/ai",
      "name": "Ai",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./context/stack.md",
      "name": "Stack",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./context/architecture.md",
      "name": "Architecture",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./context/conventions.md",
      "name": "Conventions",
      "indexType": "best",
      "autoUpdate": false
    },
    {
      "type": "knowledgeBase",
      "source": "file://./context/legacy-ref.md",
      "name": "LegacyRef",
      "indexType": "best",
      "autoUpdate": false
    }
  ],
  "hooks": {
    "agentSpawn": [
      {
        "command": "python3 .kiro/agents/scripts/agent-spawn-context.py developer",
        "timeout_ms": 5000,
        "cache_ttl_seconds": 15
      }
    ],
    "preToolUse": [
      {
        "matcher": "fs_write",
        "command": "python3 .kiro/agents/scripts/check-write-path.py developer",
        "timeout_ms": 3000
      }
    ],
    "stop": [
      {
        "command": "CHANGE=$(python3 -c \"import glob,os;c=[p for p in glob.glob('openspec/changes/*/_state.json') if '/archive/' not in p];print(os.path.dirname(max(c,key=os.path.getmtime)) if c else '')\" 2>/dev/null)\nif [ -n \"$CHANGE\" ] && [ -f \"${CHANGE}/tasks.md\" ]; then\n  TOTAL=$(grep -c '^- \\[' \"${CHANGE}/tasks.md\" 2>/dev/null || echo 0)\n  DONE=$(grep -c '^- \\[x\\]' \"${CHANGE}/tasks.md\" 2>/dev/null || echo 0)\n  echo \"\"\n  echo \"=== Tasks: ${DONE}/${TOTAL} ===\"\n  NEXT=$(grep -m1 '^- \\[ \\]' \"${CHANGE}/tasks.md\" 2>/dev/null | head -1)\n  [ -n \"$NEXT\" ] && echo \"Next: ${NEXT}\"\n  echo \"\"\n  echo \"=== Uncommitted ===\"\n  git diff --stat openspec/ src/ apps/ 2>/dev/null | tail -3 || true\nfi",
        "timeout_ms": 5000
      },
      {
        "command": "node .kiro/tools/cpp-guard.mjs --role developer 2>/dev/null || true",
        "timeout_ms": 4000
      }
    ],
    "userPromptSubmit": [
      {
        "command": "python3 -c \"\nimport json,sys,re\nd=json.load(sys.stdin)\nmsg=d.get('user_message','')\nm=re.search(r'\\b(\\d{4,6})\\b',msg)\nif m: print(f'[Auto-context] ticket_id detected: {m.group(1)}')\n\" 2>/dev/null||true",
        "timeout_ms": 1000
      }
    ]
  },
  "includeMcpJson": true,
  "model": "claude-sonnet-4.6",
  "keyboardShortcut": "ctrl+3",
  "welcomeMessage": "Developer sẵn sàng. Dùng /s4 {ticket_id} {feature-slug} để bắt đầu build."
}
