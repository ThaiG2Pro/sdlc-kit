{
  "$schema-note": "Declarative context→agent mapping. The mapper (bin/lib/context-map.mjs) reads this and (re)writes the `resources` array of each .kiro/agents/<agent>.json. Paths are relative to .kiro/ and are SKIPPED if they do not exist — so the kit never produces a broken reference. Edit this file (or let the onboarder agent edit it), then run the mapper.",

  "always": {
    "knowledgeBase": ["steering", "openspec", "sdlc.config.json", "context/project.md", "context/glossary.md"]
  },

  "agents": {
    "sdlc-full": {
      "skills": ["sdlc-orchestration-core", "spec-auditor", "cross-artifact-audit", "sprint-retro"],
      "knowledgeBase": ["context/conventions.md", "pipelines.json"]
    },
    "sdlc-fast": {
      "skills": ["sdlc-orchestration-core", "spec-auditor", "cross-artifact-audit", "sprint-retro"],
      "knowledgeBase": ["context/conventions.md", "pipelines.json"]
    },
    "analyst": {
      "skills": ["assumption-detector", "clarification-generator", "edge-case-enumerator", "php-implicit-behavior-audit", "spec-auditor", "stride-analysis"],
      "knowledgeBase": ["context/conventions.md", "context/legacy-ref.md"]
    },
    "architect": {
      "skills": ["cross-artifact-audit", "api-design", "stride-analysis", "search-first"],
      "knowledgeBase": ["ai", "context/stack.md", "context/architecture.md", "context/conventions.md", "context/legacy-ref.md"]
    },
    "developer": {
      "skills": ["verification-loop", "commit-message-helper", "security-review", "test-generator", "coding-standards", "deployment-patterns", "sonar-local", "search-first", "api-documentation-checker", "agentic-engineering"],
      "knowledgeBase": ["ai", "context/stack.md", "context/architecture.md", "context/conventions.md", "context/legacy-ref.md"]
    },
    "qa": {
      "skills": ["qa-test-design", "qa-analysis", "qa-execution", "security-audit"],
